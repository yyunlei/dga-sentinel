# ============================================================
# DGA Sentinel — 环境变量配置
# 复制为 .env 后修改: cp .env.example .env
# ============================================================
# 重要说明：
# - 下面的 KAFKA / REDIS / PG / ES / STARROCKS 等地址默认为 "localhost"，
#   适用于 *宿主机* 直连（如 scripts/seed_data.py、tests/e2e/* 在主机运行）。
# - 当应用作为 docker-compose 容器运行时，这些值会被 docker-compose.yml
#   的 environment 段强制覆盖为容器内 service name（如 kafka:9092、
#   redis:6379），无需手动改。
# - 仅密钥类（JWT_SECRET、DEEPSEEK_API_KEY、POSTGRES_PASSWORD、
#   GRAFANA_ADMIN_PASSWORD）必须在生产环境修改！
# ============================================================

# ---------- 通用 ----------
APP_ENV=development
LOG_LEVEL=INFO
TRACE_ENABLED=true
OTEL_ENDPOINT=

# ---------- API 网关 ----------
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
RATE_LIMIT_PER_MINUTE=600

# ---------- 评分服务 ----------
SCORING_HTTP_PORT=8001
SCORING_GRPC_PORT=50051
MODEL_BINARY_PATH=artifacts/binary/binary_classification_model.pkl
MODEL_MULTI_PATH=artifacts/multi/multiclass_classification_model.h5

# ---------- DAG 引擎 ----------
DAG_PIPELINE_DIR=dag_engine/pipelines

# ---------- Kafka ----------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_DNS_TOPIC=dns-query-logs
KAFKA_ALERT_TOPIC=dga-alerts

# ---------- Elasticsearch ----------
ES_HOSTS=http://localhost:9200
ES_INDEX_PREFIX=dga-events

# ---------- StarRocks ----------
STARROCKS_HOST=localhost
STARROCKS_PORT=9030
STARROCKS_HTTP_PORT=8030
STARROCKS_DB=dga_analytics

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379/0

# ---------- PostgreSQL ----------
# ⚠️ CHANGE PASSWORD IN PRODUCTION (also POSTGRES_PASSWORD below)
PG_DSN=postgresql://dga:dga_password@localhost:5432/dga_platform

# ---------- DeepSeek LLM ----------
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ---------- Prometheus ----------
PROMETHEUS_PORT=9090

# ---------- Grafana ----------
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=admin

# ---------- 补充：被代码引用但之前缺失的变量 ----------
# ⚠️ CHANGE IN PRODUCTION — must match the password embedded in PG_DSN above
POSTGRES_PASSWORD=dga_password
STARROCKS_USER=root
STARROCKS_PASSWORD=
SCORING_HOST=scoring-service

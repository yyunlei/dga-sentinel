{
  "dashboard": {
    "id": null,
    "uid": "security-audit",
    "title": "Security Audit",
    "tags": ["dga", "security"],
    "timezone": "browser",
    "refresh": "10s",
    "time": { "from": "now-1h", "to": "now" },
    "panels": [
      {
        "id": 1,
        "title": "Authentication Failures",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          { "expr": "rate(auth_failures_total[5m])", "legendFormat": "auth failures" }
        ],
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      },
      {
        "id": 2,
        "title": "Rate Limit Triggers",
        "type": "stat",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          { "expr": "increase(rate_limit_triggered_total[1h])", "legendFormat": "{{agent}}" }
        ],
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      },
      {
        "id": 3,
        "title": "RBAC Denials by Role",
        "type": "barchart",
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
        "targets": [
          { "expr": "rbac_denied_total", "legendFormat": "{{role}}" }
        ],
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      },
      {
        "id": 4,
        "title": "API Request Volume by Endpoint",
        "type": "table",
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
        "targets": [
          { "expr": "topk(10, sum by (path) (rate(http_requests_total[5m])))", "legendFormat": "{{path}}", "format": "table", "instant": true }
        ],
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      },
      {
        "id": 5,
        "title": "Anomalous Access Patterns",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
        "targets": [
          { "expr": "rate(anomalous_access_total[5m])", "legendFormat": "anomalous access" }
        ],
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }
    ]
  }
}

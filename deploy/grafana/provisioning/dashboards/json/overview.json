{
  "dashboard": {
    "id": null,
    "uid": "dga-overview",
    "title": "DGA Platform Overview",
    "tags": ["dga"],
    "timezone": "browser",
    "refresh": "10s",
    "time": { "from": "now-1h", "to": "now" },
    "panels": [
      {
        "id": 1,
        "title": "Scoring QPS",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [{ "expr": "rate(dga_score_requests_total[1m])", "legendFormat": "{{endpoint}}" }],
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      },
      {
        "id": 2,
        "title": "Scoring P95 Latency",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [{ "expr": "histogram_quantile(0.95, rate(dga_score_latency_seconds_bucket[5m]))", "legendFormat": "P95 {{model_version}}" }],
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      },
      {
        "id": 3,
        "title": "DGA Hit Rate",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
        "targets": [{ "expr": "rate(dga_hits_total[5m]) / (rate(dga_score_requests_total[5m]) > 0)", "legendFormat": "Hit Rate" }],
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      },
      {
        "id": 4,
        "title": "Error Rate",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
        "targets": [{ "expr": "rate(dga_dag_node_errors_total[5m])", "legendFormat": "{{node_id}}" }],
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      },
      {
        "id": 5,
        "title": "Rate Limit Rejections",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
        "targets": [{ "expr": "rate(dga_rate_limit_rejected_total[5m])", "legendFormat": "{{tenant_id}}" }],
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      },
      {
        "id": 6,
        "title": "Active Pipelines",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
        "targets": [{ "expr": "dga_active_pipelines", "legendFormat": "Active" }],
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }
    ],
    "schemaVersion": 39
  },
  "overwrite": true
}

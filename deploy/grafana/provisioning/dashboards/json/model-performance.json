{
  "dashboard": {
    "id": null,
    "uid": "dga-model-perf",
    "title": "Model Performance",
    "tags": ["dga", "model"],
    "timezone": "browser",
    "refresh": "30s",
    "time": { "from": "now-6h", "to": "now" },
    "panels": [
      {
        "id": 1,
        "title": "Model Version Latency",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [{ "expr": "histogram_quantile(0.95, rate(dga_score_latency_seconds_bucket[5m]))", "legendFormat": "P95 {{model_version}}" }],
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      },
      {
        "id": 2,
        "title": "DGA Family Distribution",
        "type": "piechart",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [{ "expr": "sum by (family) (dga_hits_total)", "legendFormat": "{{family}}" }],
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      },
      {
        "id": 3,
        "title": "DGA Hits by Severity",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [{ "expr": "rate(dga_hits_total[5m])", "legendFormat": "{{family}} - {{severity}}" }],
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      },
      {
        "id": 4,
        "title": "Auth Failures",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [{ "expr": "rate(dga_auth_failures_total[5m])", "legendFormat": "{{reason}}" }],
        "datasource": { "type": "prometheus", "uid": "prometheus" }
      }
    ],
    "schemaVersion": 39
  },
  "overwrite": true
}
